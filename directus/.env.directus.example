# Directus
DIRECTUS_PUBLIC_URL=https://cms.your-domain.dk
DIRECTUS_KEY=change-me-32-chars-min
DIRECTUS_SECRET=change-me-64-chars-min

# Bootstrap admin
DIRECTUS_ADMIN_EMAIL=admin@your-domain.dk
DIRECTUS_ADMIN_PASSWORD=change-me-strong

# Postgres (create in Coolify)
DIRECTUS_DB_HOST=
DIRECTUS_DB_PORT=5432
DIRECTUS_DB_DATABASE=
DIRECTUS_DB_USER=
DIRECTUS_DB_PASSWORD=

# CORS (allow Nuxt app origin)
DIRECTUS_CORS_ORIGIN=https://your-shop-domain.dk

# Optional email (password resets)
DIRECTUS_EMAIL_FROM=
DIRECTUS_EMAIL_TRANSPORT=smtp
DIRECTUS_EMAIL_SMTP_HOST=
DIRECTUS_EMAIL_SMTP_PORT=587
DIRECTUS_EMAIL_SMTP_USER=
DIRECTUS_EMAIL_SMTP_PASSWORD=
